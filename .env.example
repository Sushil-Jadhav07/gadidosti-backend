# Server
PORT=5000
NODE_ENV=development

# Public base URL of this API — used to build absolute links (e.g. KYC document urls).
# Set to https://gadidosti-backend.onrender.com in production. Falls back to the
# request's own protocol+host if left unset.
API_BASE_URL=http://localhost:5000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ssk_logistics
DB_USER=postgres
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_change_this
JWT_REFRESH_EXPIRES_IN=30d

# OTP (mock - replace with Twilio/MSG91 in production)
OTP_EXPIRY_MINUTES=10

# Google Sign-In (Google Cloud Console → Credentials → OAuth 2.0 Client ID)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Provider selection (each defaults to "fake" — a working local/dev implementation
# with no external credentials required). Swap in a real provider by changing only
# the value here and adding the corresponding implementation under src/providers/<type>/.
PAYMENT_PROVIDER=fake
SMS_PROVIDER=fake
# STORAGE_PROVIDER=fake writes to local disk (backend/uploads) — lost on every
# deploy/restart on platforms with an ephemeral filesystem (e.g. Render).
# STORAGE_PROVIDER=postgres stores files in the kyc_files table instead (run
# db/17kyc_files.sql first) — persists across deploys, no external service needed.
STORAGE_PROVIDER=fake
LOCATION_PROVIDER=fake
